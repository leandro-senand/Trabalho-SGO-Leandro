@startuml diagrama-de-componentes

skinparam componentStyle rectangle
title Sistema de Gestão das Olimpíadas (SGO)\nDiagrama de Componentes

package "Cliente" {
    [Interface Web] as UI
    [Interface Mobile] as Mobile
}

package "Servidor de Aplicação" {

    package "API Gateway" {
        [Autenticação / JWT] as Auth
        [Roteador de Requisições] as Router
    }

    package "Módulo de Competições" {
        [Gerenciamento de Competições] as GC
        [Validação de Regras] as VR
    }

    package "Módulo de Inscrições" {
        [Gerenciamento de Inscrições] as GI
        [Validação de Atletas] as VA
    }

    package "Módulo de Alocação" {
        [Gerenciamento de Locais] as GL
        [Verificação de Conflitos] as VC
    }

    package "Módulo de Resultados" {
        [Registro de Resultados] as RR
        [Cálculo de Medalhas] as CM
    }

    package "Módulo de Relatórios" {
        [Gerador de Relatórios] as GR
        [Exportador de Dados] as ED
    }

    package "Módulo de Países e Atletas" {
        [Cadastro de Países] as CP
        [Cadastro de Atletas] as CA
    }
}

package "Serviços Externos" {
    [Serviço de E-mail] as Email
    [Serviço de Armazenamento] as Storage
}

package "Banco de Dados" {
    database "SGO_DB" as DB
    database "Cache Redis" as Cache
}

UI --> Auth : HTTPS
Mobile --> Auth : HTTPS
Auth --> Router : valida token

Router --> GC
Router --> GI
Router --> GL
Router --> RR
Router --> GR
Router --> CP
Router --> CA

GC --> VR
GC --> DB
GI --> VA
GI --> DB
GL --> VC
GL --> DB
RR --> CM
RR --> DB
CM --> DB
GR --> ED
GR --> DB
CP --> DB
CA --> DB

GI --> Email : notificações
GR --> Storage : exporta PDF/Excel
Router --> Cache : leitura rápida
DB --> Cache : sincroniza

@enduml
