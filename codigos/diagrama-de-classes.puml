@startuml diagrama-de-classes

skinparam classAttributeIconSize 0
skinparam classFontStyle bold
title Sistema de Gestão das Olimpíadas (SGO)\nDiagrama de Classes

class Pais {
    - id: Long
    - nome: String
    - codigo: String
    - bandeira: String
    + getId(): Long
    + getNome(): String
    + getCodigo(): String
    + getAtletas(): List<Atleta>
    + getMedalhas(): List<Medalha>
}

class Atleta {
    - id: Long
    - nome: String
    - dataNascimento: Date
    - documento: String
    - pais: Pais
    + getId(): Long
    + getNome(): String
    + getPais(): Pais
    + getInscricoes(): List<Inscricao>
}

class Competicao {
    - id: Long
    - modalidade: String
    - data: Date
    - horario: Time
    - status: StatusCompeticao
    + getId(): Long
    + getModalidade(): String
    + getData(): Date
    + getHorario(): Time
    + getLocal(): Local
    + getAtletas(): List<Atleta>
    + getResultado(): Resultado
}

class Local {
    - id: Long
    - nome: String
    - endereco: String
    - capacidade: Integer
    + getId(): Long
    + getNome(): String
    + getCapacidade(): Integer
    + verificarDisponibilidade(data: Date, horario: Time): Boolean
}

class Inscricao {
    - id: Long
    - dataInscricao: Date
    - status: StatusInscricao
    - paisRepresentado: Pais
    + getId(): Long
    + getAtleta(): Atleta
    + getCompeticao(): Competicao
    + getPaisRepresentado(): Pais
    + cancelar(): void
}

class Resultado {
    - id: Long
    - dataRegistro: Date
    + getId(): Long
    + getCompeticao(): Competicao
    + getPrimeiro(): Atleta
    + getSegundo(): Atleta
    + getTerceiro(): Atleta
    + registrar(primeiro: Atleta, segundo: Atleta, terceiro: Atleta): void
}

class Medalha {
    - id: Long
    - tipo: TipoMedalha
    - competicao: Competicao
    - atleta: Atleta
    - pais: Pais
    + getId(): Long
    + getTipo(): TipoMedalha
    + getAtleta(): Atleta
    + getPais(): Pais
}

class RelatorioMedalhas {
    - id: Long
    - dataGeracao: Date
    + gerar(): void
    + getPorPais(): Map<Pais, List<Medalha>>
    + getTotais(): Map<Pais, Integer>
    + exportar(): String
}

class AlocacaoLocal {
    - id: Long
    - data: Date
    - horarioInicio: Time
    - horarioFim: Time
    + getId(): Long
    + getLocal(): Local
    + getCompeticao(): Competicao
    + verificarConflito(): Boolean
}

enum StatusCompeticao {
    AGENDADA
    EM_ANDAMENTO
    FINALIZADA
    CANCELADA
}

enum StatusInscricao {
    ATIVA
    CANCELADA
    PENDENTE
}

enum TipoMedalha {
    OURO
    PRATA
    BRONZE
}

Pais "1" o-- "0..*" Atleta : possui
Atleta "0..*" -- "0..*" Competicao : participa
Atleta "1" -- "0..*" Inscricao : realiza
Competicao "1" -- "0..*" Inscricao : recebe
Competicao "0..*" -- "1" Local : realizada em
Competicao "1" -- "0..1" Resultado : possui
Resultado "1" --> "1..3" Medalha : gera
Medalha "0..*" --> "1" Pais : pertence
Medalha "0..*" --> "1" Atleta : concedida a
RelatorioMedalhas "1" --> "0..*" Medalha : consolida
Local "1" -- "0..*" AlocacaoLocal : recebe
Competicao "1" -- "0..1" AlocacaoLocal : referencia
Inscricao --> StatusInscricao
Competicao --> StatusCompeticao
Medalha --> TipoMedalha

@enduml
